APP_NAME="HR Server"
APP_DESCRIPTION="HR production backend"
APP_VERSION="1.0.0"

ENVIRONMENT="production"
DATABASE_BACKEND="mysql"

SECRET_KEY="replace-with-a-real-secret"
ALGORITHM="HS256"

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=15
ADMIN_ACCESS_TOKEN_EXPIRE_MINUTES=15
ADMIN_REFRESH_TOKEN_EXPIRE_DAYS=30
ENABLE_LOCAL_AUTH_BYPASS=false
ENABLE_LOCAL_ADMIN_BOOTSTRAP=false

FILE_LOG_DIR="/var/log/hr-server"
FILE_LOG_FILENAME=""
FILE_LOG_LEVEL="INFO"

MYSQL_USER="hr_prod"
MYSQL_PASSWORD="replace-with-a-real-db-password"
MYSQL_SERVER="127.0.0.1"
MYSQL_PORT=3306
MYSQL_DB="hr_prod"

REDIS_CACHE_HOST="127.0.0.1"
REDIS_CACHE_PORT=6379
REDIS_CONNECT_TIMEOUT_SECONDS=2
REDIS_SOCKET_TIMEOUT_SECONDS=2
HEALTH_CHECK_TIMEOUT_SECONDS=2

EVENT_QUEUE_PREFIX="hr-prod:"
EVENT_CONSUMER_GROUP="hr_prod_event_consumer"
EVENT_CONSUMER_CONCURRENCY=3
EVENT_CONSUMER_BUFFER_SIZE=12
EVENT_CONSUMER_MAX_DELIVERIES=5
EVENT_CONSUMER_SHUTDOWN_TIMEOUT_SECONDS=10
EVENT_STATS_INTERVAL=30
EVENT_PENDING_IDLE_MS=60000
EVENT_DEAD_LETTER_MAXLEN=10000
EVENT_DEAD_LETTER_RAW_MAX_CHARS=4000
EVENT_DEAD_LETTER_ERROR_MAX_CHARS=500
EVENT_OUTBOX_BATCH_SIZE=50
EVENT_OUTBOX_LEASE_SECONDS=60
EVENT_OUTBOX_POLL_SECONDS=1

MAIL_DELIVERY_MODE="smtp"
MAIL_CREDENTIAL_ENCRYPTION_KEY="replace-with-a-fernet-key"
MAIL_TASK_PROCESSING_LEASE_SECONDS=120
MAIL_TASK_RECOVERY_INTERVAL_SECONDS=30
MAIL_TASK_RECOVERY_BATCH_SIZE=50

CANDIDATE_WEB_BASE_URL="https://www.primnota.com"
CANDIDATE_REGISTER_VERIFICATION_ENABLED=true
CANDIDATE_REGISTER_VERIFICATION_SENDER_NAME="T-Maxx Recruit"
CANDIDATE_REGISTER_VERIFICATION_SENDER_EMAIL="replace-with-sender@example.com"
CANDIDATE_REGISTER_VERIFICATION_SMTP_USERNAME="replace-with-smtp-username"
CANDIDATE_REGISTER_VERIFICATION_SMTP_HOST="replace-with-smtp-host"
CANDIDATE_REGISTER_VERIFICATION_SMTP_PORT=465
CANDIDATE_REGISTER_VERIFICATION_SMTP_SECURITY_MODE="ssl"
CANDIDATE_REGISTER_VERIFICATION_AUTH_SECRET="replace-with-smtp-secret"

ASSET_STORAGE_PROVIDER="local"
ASSET_STORAGE_DIR="/srv/hr-server/src/storage/assets"
ASSET_STORAGE_KEY_PREFIX="hr-assets"
ASSET_MAX_UPLOAD_BYTES=26214400
ASSET_UPLOAD_CHUNK_BYTES=1048576
ASSET_BATCH_MAX_FILES=50
ASSET_BATCH_MAX_BYTES=104857600
ASSET_ZIP_SPOOL_MAX_BYTES=8388608

CORS_ORIGINS=["https://www.primnota.com","https://admin.primnota.com","https://primnota.com"]

WEB_GUNICORN_BIND="127.0.0.1:8000"
WEB_GUNICORN_WORKERS=1
WEB_GUNICORN_TIMEOUT=60
WEB_GUNICORN_GRACEFUL_TIMEOUT=30
WEB_GUNICORN_KEEPALIVE=5

ADMIN_GUNICORN_BIND="127.0.0.1:8001"
ADMIN_GUNICORN_WORKERS=1
ADMIN_GUNICORN_TIMEOUT=60
ADMIN_GUNICORN_GRACEFUL_TIMEOUT=30
ADMIN_GUNICORN_KEEPALIVE=5
