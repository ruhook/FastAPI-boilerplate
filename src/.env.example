DATABASE_BACKEND="mysql"

APP_NAME="HR Server"
APP_DESCRIPTION="Shared backend baseline for web and admin"
APP_VERSION="0.1.0"
ENVIRONMENT="local"
ENABLE_LOCAL_AUTH_BYPASS=true
ENABLE_LOCAL_ADMIN_BOOTSTRAP=false
ALLOW_TEST_DATABASE_CLEANUP=false
TEST_DATABASE_NAME_ALLOWLIST="hr_server"

SECRET_KEY="change-this-secret-key"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=15
ADMIN_ACCESS_TOKEN_EXPIRE_MINUTES=15
ADMIN_REFRESH_TOKEN_EXPIRE_DAYS=30

FILE_LOG_DIR=/var/log/hr-server
FILE_LOG_FILENAME=""

MYSQL_USER="hr_user"
MYSQL_PASSWORD="change-this-db-password"
MYSQL_SERVER="localhost"
MYSQL_PORT=3306
MYSQL_DB="hr_server"
DATABASE_POOL_PRE_PING=true
DATABASE_POOL_RECYCLE_SECONDS=1800

REDIS_CACHE_HOST="localhost"
REDIS_CACHE_PORT=6379

AUTH_RATE_LIMIT_PREFIX="auth:rate-limit:"
AUTH_LOGIN_WINDOW_SECONDS=300
AUTH_LOGIN_IP_LIMIT=30
AUTH_LOGIN_IDENTIFIER_LIMIT=10
AUTH_LOGIN_PAIR_LIMIT=5
AUTH_VERIFICATION_SEND_WINDOW_SECONDS=3600
AUTH_VERIFICATION_SEND_IP_LIMIT=10
AUTH_VERIFICATION_SEND_IDENTIFIER_LIMIT=3
AUTH_VERIFICATION_CHECK_WINDOW_SECONDS=600
AUTH_VERIFICATION_CHECK_IP_LIMIT=30
AUTH_VERIFICATION_CHECK_IDENTIFIER_LIMIT=10

EVENT_QUEUE_PREFIX="hr-mq:"
EVENT_CONSUMER_GROUP="hr_event_consumer"
EVENT_CONSUMER_CONCURRENCY=3
EVENT_STATS_INTERVAL=30
EVENT_PENDING_IDLE_MS=60000
EVENT_OUTBOX_BATCH_SIZE=50
EVENT_OUTBOX_LEASE_SECONDS=60
EVENT_OUTBOX_POLL_SECONDS=1.0

CANDIDATE_WEB_BASE_URL="http://localhost:3002"
CANDIDATE_REGISTER_VERIFICATION_ENABLED=true
CANDIDATE_REGISTER_VERIFICATION_SENDER_NAME="T-Maxx Recruit"
CANDIDATE_REGISTER_VERIFICATION_SENDER_EMAIL="your-sender@example.com"
CANDIDATE_REGISTER_VERIFICATION_SMTP_USERNAME="your-sender@example.com"
CANDIDATE_REGISTER_VERIFICATION_SMTP_HOST="smtp.example.com"
CANDIDATE_REGISTER_VERIFICATION_SMTP_PORT=465
CANDIDATE_REGISTER_VERIFICATION_SMTP_SECURITY_MODE="ssl"
CANDIDATE_REGISTER_VERIFICATION_AUTH_SECRET="replace-with-your-mail-app-password"
CANDIDATE_REGISTER_VERIFICATION_SUBJECT="Your verification code"
CANDIDATE_REGISTER_VERIFICATION_CODE_TTL_SECONDS=600
CANDIDATE_REGISTER_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
CANDIDATE_REGISTER_VERIFICATION_MAX_ATTEMPTS=5
CANDIDATE_REGISTER_VERIFICATION_CODE_LENGTH=6
CANDIDATE_REGISTER_VERIFICATION_REDIS_PREFIX="candidate:register:verification:"
MAIL_CREDENTIAL_ENCRYPTION_KEY=""

ASSET_STORAGE_PROVIDER="aliyun_oss"
ASSET_STORAGE_DIR="./src/storage/assets"
ASSET_STORAGE_KEY_PREFIX="hr-assets/local"
ASSET_MAX_UPLOAD_BYTES=26214400
ASSET_UPLOAD_CHUNK_BYTES=1048576
ASSET_BATCH_MAX_FILES=50
ASSET_BATCH_MAX_BYTES=104857600
ASSET_ZIP_SPOOL_MAX_BYTES=8388608
ALIYUN_OSS_ENDPOINT="https://oss-ap-southeast-1.aliyuncs.com"
ALIYUN_OSS_ACCESS_KEY_ID="replace-with-your-aliyun-access-key-id"
ALIYUN_OSS_ACCESS_KEY_SECRET="replace-with-your-aliyun-access-key-secret"
ALIYUN_OSS_BUCKET_PRODUCTION="primnota"
ALIYUN_OSS_BUCKET_NON_PRODUCTION="primnota-test"

CORS_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=true
