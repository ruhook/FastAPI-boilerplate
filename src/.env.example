DATABASE_BACKEND="mysql"

APP_NAME="HR Server"
APP_DESCRIPTION="Shared backend baseline for web and admin"
APP_VERSION="0.1.0"
ENVIRONMENT="local"
ALLOW_TEST_DATABASE_CLEANUP=false
TEST_DATABASE_NAME_ALLOWLIST="hr_server"

SECRET_KEY="change-this-secret-key"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ADMIN_ACCESS_TOKEN_EXPIRE_MINUTES=43200
ADMIN_REFRESH_TOKEN_EXPIRE_DAYS=30

FILE_LOG_DIR=/var/log/hr-server
FILE_LOG_FILENAME=""

MYSQL_USER="hr_user"
MYSQL_PASSWORD="change-this-db-password"
MYSQL_SERVER="localhost"
MYSQL_PORT=3306
MYSQL_DB="hr_server"

REDIS_CACHE_HOST="localhost"
REDIS_CACHE_PORT=6379

EVENT_QUEUE_PREFIX="hr-mq:"
EVENT_CONSUMER_GROUP="hr_event_consumer"
EVENT_CONSUMER_CONCURRENCY=3
EVENT_STATS_INTERVAL=30

CORS_ORIGINS=["*"]
